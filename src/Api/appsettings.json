{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/binancebot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=BinanceBot;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Admin": {
    "Key": "dev-admin-key-change-me"
  },
  "Binance": {
    "RestBaseUrl": "https://testnet.binance.vision",
    "WsBaseUrl": "wss://stream.testnet.binance.vision",
    "Symbols": [ "BTCUSDT", "BNBUSDT", "XRPUSDT" ],
    "KlineIntervals": [ "1m", "1h" ],
    "DepthSnapshotLimit": 1000,
    "RestTimeoutMs": 10000,
    "WsReconnectInitialDelayMs": 500,
    "WsReconnectMaxDelayMs": 30000,
    "WsPingIntervalMs": 20000,
    "WsPongTimeoutMs": 60000,
    "BackfillEnabled": true,
    "BackfillLimit": 1000,
    "BackfillIntervals": [ "1m", "1h" ],
    "AllowMainnet": false
  },
  "PaperFill": {
    "FixedSlippagePct": 0.0001,
    "SimulatedLatencyMs": 100,
    "UseBnbFeeDiscount": false
  },
  "RiskProfile": {
    "Defaults": {
      "RiskPerTradePct": 0.02,
      "MaxPositionSizePct": 0.40,
      "MaxDrawdown24hPct": 0.20,
      "MaxDrawdownAllTimePct": 0.40,
      "MaxConsecutiveLosses": 10,
      "MaxOpenPositions": 2
    }
  },
  "Strategies": {
    "Seed": [
      {
        "Name": "BTC-VwapEma-Scalper",
        "Type": "VwapEmaHybrid",
        "Symbols": [ "BTCUSDT" ],
        "ParametersJson": "{\"EmaPeriod\":21,\"EmaTimeframe\":\"1h\",\"VwapWindowBars\":1440,\"SlopeTolerance\":-0.0005,\"VwapTolerancePct\":0.0015,\"VolumeMultiplier\":1.05,\"StopPct\":0.003,\"TpGrossPct\":0.007,\"SwingLookback\":20,\"TpSafetyFactor\":0.95,\"MaxHoldMinutes\":12}",
        "Activate": true
      },
      {
        "Name": "BNB-VwapEma-Scalper",
        "Type": "VwapEmaHybrid",
        "Symbols": [ "BNBUSDT" ],
        "ParametersJson": "{\"EmaPeriod\":21,\"EmaTimeframe\":\"1h\",\"VwapWindowBars\":1440,\"SlopeTolerance\":-0.0005,\"VwapTolerancePct\":0.0015,\"VolumeMultiplier\":1.05,\"StopPct\":0.003,\"TpGrossPct\":0.007,\"SwingLookback\":20,\"TpSafetyFactor\":0.95,\"MaxHoldMinutes\":12}",
        "Activate": true
      },
      {
        "Name": "XRP-VwapEma-Scalper",
        "Type": "VwapEmaHybrid",
        "Symbols": [ "XRPUSDT" ],
        "ParametersJson": "{\"EmaPeriod\":21,\"EmaTimeframe\":\"1h\",\"VwapWindowBars\":1440,\"SlopeTolerance\":-0.0005,\"VwapTolerancePct\":0.0015,\"VolumeMultiplier\":1.05,\"StopPct\":0.004,\"TpGrossPct\":0.007,\"SwingLookback\":20,\"TpSafetyFactor\":0.95,\"MaxHoldMinutes\":12}",
        "Activate": true
      }
    ]
  }
}
