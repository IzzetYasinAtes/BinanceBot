{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/binancebot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=BinanceBot;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Admin": {
    "Key": "dev-admin-key-change-me"
  },
  "Binance": {
    "RestBaseUrl": "https://testnet.binance.vision",
    "WsBaseUrl": "wss://stream.testnet.binance.vision",
    "Symbols": [ "BTCUSDT", "ETHUSDT", "BNBUSDT" ],
    "KlineIntervals": [ "1m" ],
    "DepthSnapshotLimit": 1000,
    "RestTimeoutMs": 10000,
    "WsReconnectInitialDelayMs": 500,
    "WsReconnectMaxDelayMs": 30000,
    "WsPingIntervalMs": 20000,
    "WsPongTimeoutMs": 60000,
    "AllowMainnet": false
  }
}
